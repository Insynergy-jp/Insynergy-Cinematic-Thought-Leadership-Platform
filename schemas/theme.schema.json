{
  "$id": "https://schemas.insynergy.co/cttp/v2.0/story/theme.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    {
      "$ref": "https://schemas.insynergy.co/cttp/v2.0/common/defs.schema.json"
    }
  ],
  "description": "Primary theme selection with score and rejected alternatives. Owner 2.1.2.",
  "properties": {
    "build_id": {
      "$ref": "https://schemas.insynergy.co/cttp/v2.0/common/defs.schema.json#/$defs/BuildId"
    },
    "content_hash": {
      "$ref": "https://schemas.insynergy.co/cttp/v2.0/common/defs.schema.json#/$defs/ContentHash"
    },
    "generated_at": {
      "$ref": "https://schemas.insynergy.co/cttp/v2.0/common/defs.schema.json#/$defs/Iso8601"
    },
    "primary_theme": {
      "minLength": 1,
      "type": "string"
    },
    "rejected_themes": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array"
    },
    "schema_version": {
      "$ref": "https://schemas.insynergy.co/cttp/v2.0/common/defs.schema.json#/$defs/SchemaVersion"
    },
    "theme_score": {
      "$ref": "https://schemas.insynergy.co/cttp/v2.0/common/defs.schema.json#/$defs/Score"
    }
  },
  "required": [
    "schema_version",
    "build_id",
    "generated_at",
    "content_hash",
    "primary_theme",
    "theme_score",
    "rejected_themes"
  ],
  "title": "Theme",
  "type": "object",
  "unevaluatedProperties": false
}
