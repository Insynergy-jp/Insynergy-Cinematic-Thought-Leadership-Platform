{
  "$id": "https://schemas.insynergy.co/cttp/v3.4/preview/image-prompt-set.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "build_id": {
      "maxLength": 20000,
      "minLength": 1,
      "type": "string"
    },
    "contract_version": {
      "const": "image-prompt-set/1"
    },
    "image_quality": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "image_size": {
      "enum": [
        "1024x1024",
        "1536x1024",
        "1024x1536"
      ]
    },
    "output_format": {
      "enum": [
        "png",
        "jpeg",
        "webp"
      ]
    },
    "plan_key": {
      "pattern": "^sha256:[a-f0-9]{64}$",
      "type": "string"
    },
    "prompts": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "aspect_ratio": {
            "maxLength": 20000,
            "minLength": 1,
            "type": "string"
          },
          "execution_status": {
            "const": "SEALED_NOT_AUTHORIZED"
          },
          "negative_constraints": {
            "items": {
              "maxLength": 20000,
              "minLength": 1,
              "type": "string"
            },
            "maxItems": 32,
            "type": "array"
          },
          "order": {
            "minimum": 1,
            "type": "integer"
          },
          "prompt": {
            "maxLength": 20000,
            "minLength": 1,
            "type": "string"
          },
          "prompt_id": {
            "maxLength": 20000,
            "minLength": 1,
            "type": "string"
          },
          "safety_constraints": {
            "items": {
              "maxLength": 20000,
              "minLength": 1,
              "type": "string"
            },
            "maxItems": 32,
            "type": "array"
          },
          "shot_id": {
            "maxLength": 20000,
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "prompt_id",
          "shot_id",
          "order",
          "prompt"
        ],
        "type": "object"
      },
      "maxItems": 128,
      "minItems": 1,
      "type": "array"
    },
    "schema_version": {
      "const": "3.4.0"
    }
  },
  "required": [
    "schema_version",
    "contract_version",
    "build_id",
    "plan_key",
    "image_size",
    "image_quality",
    "output_format",
    "prompts"
  ],
  "title": "ImagePromptSet",
  "type": "object"
}
