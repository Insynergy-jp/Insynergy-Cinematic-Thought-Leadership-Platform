{
  "$id": "https://schemas.insynergy.co/cttp/v2.0/quality/quality-gate-report.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_id": {"type": "string", "minLength": 1},
    "artifact_type": {"const": "quality_gate_report"},
    "build_id": {"type": "string", "minLength": 1},
    "content_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "contract_version": {"const": "2.0"},
    "data": {
      "type": "object",
      "required": [
        "report_id",
        "build_id",
        "gate_id",
        "decision",
        "passed",
        "mandatory_checks",
        "artifact_refs",
        "configuration_hash",
        "lifecycle",
        "content_hash"
      ]
    },
    "generated_at": {"type": "string", "format": "date-time"},
    "provenance": {
      "type": "object",
      "required": ["generator", "input_hashes", "deterministic"]
    },
    "schema_version": {"const": "2.0"}
  },
  "required": [
    "schema_version",
    "contract_version",
    "artifact_type",
    "artifact_id",
    "build_id",
    "content_hash",
    "generated_at",
    "provenance",
    "data"
  ],
  "title": "QualityGateReportEnvelope",
  "type": "object"
}
