{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.insynergy.co/cttp/v3.3/persona/persona.schema.json",
  "title": "CanonicalPersona",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "contract_version", "persona_id", "build_id",
    "deliberation_key", "article_hash", "creative_brief_hash",
    "role", "job_to_be_done", "dominant_desire", "dominant_fear",
    "internal_contradiction", "decision_pressure", "authority_boundary",
    "current_workaround", "emotional_arc_candidate", "evidence",
    "assumptions", "prohibited_inventions", "unresolved_questions",
    "source_fidelity", "story_usability", "agent_provenance",
    "generated_at", "content_hash"
  ],
  "properties": {
    "schema_version": {"const": "3.3.0"},
    "contract_version": {"const": "persona-council/1"},
    "persona_id": {"type": "string", "pattern": "^PER-[A-Za-z0-9._:-]{8,128}$"},
    "build_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "deliberation_key": {"$ref": "#/$defs/ContentHash"},
    "article_hash": {"$ref": "#/$defs/ContentHash"},
    "creative_brief_hash": {"$ref": "#/$defs/ContentHash"},
    "role": {"$ref": "#/$defs/PersonaField"},
    "job_to_be_done": {"$ref": "#/$defs/PersonaField"},
    "dominant_desire": {"$ref": "#/$defs/PersonaField"},
    "dominant_fear": {"$ref": "#/$defs/PersonaField"},
    "internal_contradiction": {"$ref": "#/$defs/PersonaField"},
    "decision_pressure": {"$ref": "#/$defs/PersonaField"},
    "authority_boundary": {"$ref": "#/$defs/PersonaField"},
    "current_workaround": {"$ref": "#/$defs/PersonaField"},
    "emotional_arc_candidate": {"$ref": "#/$defs/PersonaField"},
    "evidence": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"$ref": "#/$defs/EvidenceRef"}},
    "assumptions": {"type": "array", "maxItems": 32, "items": {"$ref": "#/$defs/Assumption"}},
    "prohibited_inventions": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"enum": ["DEMOGRAPHICS", "FABRICATED_QUOTE", "MEDICAL_CONDITION", "TRAUMA", "VULNERABLE_SETTING", "PERSONAL_HISTORY", "UNSUPPORTED_RELATIONSHIP"]}
    },
    "unresolved_questions": {"type": "array", "maxItems": 16, "items": {"type": "string", "minLength": 1, "maxLength": 500}},
    "source_fidelity": {"type": "number", "minimum": 0, "maximum": 1},
    "story_usability": {"type": "number", "minimum": 0, "maximum": 1},
    "agent_provenance": {"$ref": "#/$defs/AgentProvenance"},
    "generated_at": {"type": "string", "format": "date-time"},
    "content_hash": {"$ref": "#/$defs/ContentHash"}
  },
  "$defs": {
    "ContentHash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "PersonaField": {
      "type": "object", "additionalProperties": false,
      "required": ["value", "basis", "evidence_refs"],
      "properties": {
        "value": {"type": "string", "minLength": 1, "maxLength": 1000},
        "basis": {"enum": ["SOURCE", "CREATIVE_BRIEF", "ASSUMPTION"]},
        "evidence_refs": {"type": "array", "maxItems": 16, "items": {"type": "string", "minLength": 1, "maxLength": 256}}
      }
    },
    "EvidenceRef": {
      "type": "object", "additionalProperties": false,
      "required": ["evidence_id", "artifact_hash", "json_pointer", "summary"],
      "properties": {
        "evidence_id": {"type": "string", "minLength": 1, "maxLength": 128},
        "artifact_hash": {"$ref": "#/$defs/ContentHash"},
        "json_pointer": {"type": "string", "maxLength": 512},
        "summary": {"type": "string", "minLength": 1, "maxLength": 1000}
      }
    },
    "Assumption": {
      "type": "object", "additionalProperties": false,
      "required": ["assumption_id", "statement", "rationale", "risk", "requires_human_attention"],
      "properties": {
        "assumption_id": {"type": "string", "minLength": 1, "maxLength": 128},
        "statement": {"type": "string", "minLength": 1, "maxLength": 1000},
        "rationale": {"type": "string", "minLength": 1, "maxLength": 1000},
        "risk": {"enum": ["LOW", "MEDIUM", "HIGH"]},
        "requires_human_attention": {"type": "boolean"}
      }
    },
    "AgentProvenance": {
      "type": "object", "additionalProperties": false,
      "required": ["sdk_version", "manager_agent_version", "prompt_version", "policy_version", "models_by_role"],
      "properties": {
        "sdk_version": {"type": "string", "minLength": 1, "maxLength": 64},
        "manager_agent_version": {"type": "string", "minLength": 1, "maxLength": 64},
        "prompt_version": {"type": "string", "minLength": 1, "maxLength": 64},
        "policy_version": {"type": "string", "minLength": 1, "maxLength": 64},
        "models_by_role": {
          "type": "object", "minProperties": 5, "maxProperties": 5,
          "propertyNames": {"enum": ["audience_researcher", "empathy_narrative_analyst", "brand_strategist", "red_team_critic", "persona_manager"]},
          "additionalProperties": {"type": "string", "minLength": 1, "maxLength": 128}
        }
      }
    },
    "Usage": {
      "type": "object", "additionalProperties": false,
      "required": ["input_tokens", "output_tokens", "total_tokens", "estimated_cost_usd"],
      "properties": {
        "input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "total_tokens": {"type": "integer", "minimum": 0},
        "estimated_cost_usd": {"type": "number", "minimum": 0}
      }
    }
  }
}
