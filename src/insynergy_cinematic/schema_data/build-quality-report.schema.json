{
  "$id": "https://schemas.insynergy.co/cttp/v2.0/quality/build-quality-report.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_id": {"type": "string", "minLength": 1},
    "artifact_type": {"enum": ["build_quality_report", "published_build_quality_report"]},
    "build_id": {"type": "string", "minLength": 1},
    "content_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "contract_version": {"const": "2.0"},
    "data": {
      "type": "object",
      "required": [
        "build_id",
        "report_count",
        "passed_gate_count",
        "failed_gate_count",
        "gate_scores",
        "quality_score",
        "regressions",
        "drill_down",
        "content_hash"
      ]
    },
    "generated_at": {"type": "string", "format": "date-time"},
    "provenance": {
      "type": "object",
      "required": ["generator", "input_hashes", "deterministic"]
    },
    "schema_version": {"const": "2.0"}
  },
  "required": [
    "schema_version",
    "contract_version",
    "artifact_type",
    "artifact_id",
    "build_id",
    "content_hash",
    "generated_at",
    "provenance",
    "data"
  ],
  "title": "BuildQualityReportEnvelope",
  "type": "object"
}
