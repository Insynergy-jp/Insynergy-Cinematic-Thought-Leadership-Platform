{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.insynergy.co/cttp/v3.3/persona/persona-quality-report.schema.json",
  "title": "PersonaQualityReport",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "contract_version", "report_id", "build_id", "deliberation_key", "article_hash", "creative_brief_hash", "proposal_set_hash", "red_team_report_hash", "deliberation_hash", "persona_hash", "status", "checks", "non_waivable_failures", "findings", "policy_version", "generated_at", "content_hash"],
  "properties": {
    "schema_version": {"const": "3.3.0"},
    "contract_version": {"const": "persona-quality/1"},
    "report_id": {"type": "string", "pattern": "^PQR-[A-Za-z0-9._:-]{8,128}$"},
    "build_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "deliberation_key": {"$ref": "persona.schema.json#/$defs/ContentHash"},
    "article_hash": {"$ref": "persona.schema.json#/$defs/ContentHash"},
    "creative_brief_hash": {"$ref": "persona.schema.json#/$defs/ContentHash"},
    "proposal_set_hash": {"$ref": "persona.schema.json#/$defs/ContentHash"},
    "red_team_report_hash": {"$ref": "persona.schema.json#/$defs/ContentHash"},
    "deliberation_hash": {"$ref": "persona.schema.json#/$defs/ContentHash"},
    "persona_hash": {"$ref": "persona.schema.json#/$defs/ContentHash"},
    "status": {"enum": ["PASS", "MANUAL_REVIEW_REQUIRED", "UNAVAILABLE", "ERROR"]},
    "checks": {"type": "array", "minItems": 10, "maxItems": 10, "items": {"$ref": "#/$defs/Check"}},
    "non_waivable_failures": {"type": "array", "maxItems": 32, "uniqueItems": true, "items": {"enum": ["SCHEMA", "HASH", "EVIDENCE", "SECRET", "CARDINALITY", "APPROVAL_BINDING"]}},
    "findings": {"type": "array", "maxItems": 100, "items": {"$ref": "#/$defs/Finding"}},
    "policy_version": {"type": "string", "minLength": 1, "maxLength": 64},
    "generated_at": {"type": "string", "format": "date-time"},
    "content_hash": {"$ref": "persona.schema.json#/$defs/ContentHash"}
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "PASS"}}},
      "then": {
        "properties": {
          "checks": {"items": {"properties": {"passed": {"const": true}}}},
          "non_waivable_failures": {"maxItems": 0}
        }
      }
    }
  ],
  "$defs": {
    "Check": {
      "type": "object", "additionalProperties": false,
      "required": ["check_id", "passed", "evidence_hashes"],
      "properties": {
        "check_id": {"enum": ["proposal_cardinality", "red_team_resolution", "manager_synthesis", "factual_evidence", "assumption_lineage", "prohibited_inventions", "persona_singularity", "story_usability", "identity_integrity", "security_hygiene"]},
        "passed": {"type": "boolean"},
        "evidence_hashes": {"type": "array", "minItems": 1, "maxItems": 16, "items": {"$ref": "persona.schema.json#/$defs/ContentHash"}}
      }
    },
    "Finding": {
      "type": "object", "additionalProperties": false,
      "required": ["code", "severity", "waivable", "summary", "evidence_refs"],
      "properties": {
        "code": {"type": "string", "pattern": "^PQ-[A-Z0-9_]{3,64}$"},
        "severity": {"enum": ["INFO", "WARNING", "BLOCKING"]},
        "waivable": {"type": "boolean"},
        "summary": {"type": "string", "minLength": 1, "maxLength": 1000},
        "evidence_refs": {"type": "array", "minItems": 1, "maxItems": 16, "items": {"type": "string", "minLength": 1, "maxLength": 256}}
      }
    }
  }
}
