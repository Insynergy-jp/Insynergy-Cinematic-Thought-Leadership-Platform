{
  "schema_version": "2.0",
  "platform_version": "3.0.0",
  "profile": "preview",
  "deterministic": true,
  "render": {
    "provider": "local",
    "max_parallel_shots": 4,
    "max_attempts": 3,
    "quality_threshold": 0.9,
    "budget_usd": 20.0,
    "estimate_before_submission": true,
    "preview": {
      "width": 1280,
      "height": 720,
      "frame_rate": 24,
      "max_duration_seconds": 5
    },
    "final": {
      "width": 1920,
      "height": 1080,
      "frame_rate": 24,
      "max_duration_seconds": 10
    }
  },
  "story": {
    "concept_ratio_max": 0.2,
    "supporting_role_max": 3
  },
  "quality": {
    "fail_closed": true
  },
  "agent_review": {
    "mode": "off",
    "model": "gpt-5.6-sol",
    "reasoning_effort": "medium",
    "trace_mode": "disabled",
    "timeout_seconds": 120,
    "max_input_bytes": 524288,
    "max_output_tokens": 16000,
    "agent_version": "3.0.1",
    "prompt_version": "agent-review-v1",
    "allowed_models": ["gpt-5.6-sol"],
    "policy_version": "agent-review-policy/1"
  }
}
